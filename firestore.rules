//   allow write: if request.auth != null && request.auth.uid in request.resource.data.participantUids;
// }
// match /clubs/{id} {
//   allow read: if request.auth != null;
//   allow create: if request.auth != null && request.resource.data.adminId == request.auth.uid;
//   // Update rule intentionally omitted — needs a real "only your own uid was
//   // added/removed from memberIds/pendingIds, OR you're already adminId/in
//   // moderatorIds" check, which needs emulator testing to get right without
