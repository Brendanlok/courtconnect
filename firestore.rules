rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read anyone's profile (needed for username lookup, club
    // member resolution, chat headers, etc.) but only write their own.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      // Per-user subcollections — always written by their own owner (uid),
      // never by anyone else. Every function in firestoreService.ts that
      // touches these already only ever writes to auth.currentUser's own uid.
      match /{sub}/{docId} where sub in ['matches', 'plannedMatches', 'tournamentRegs', 'conversations', 'friends'] {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Endorsements are the one subcollection someone ELSE writes into —
      // fromUid (the endorser) writes their own doc under the target's uid.
      match /endorsements/{fromUid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == fromUid;
      }
    }

    // Everything else (liveMatches, challenges, conversations, clubs) is
    // left permissive for now — see the note below on why.
    match /{collection}/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

// ── Not yet applied: proposed tighter rules for the shared, multi-party
// collections (challenges, conversations, clubs). These need real per-field
// write validation (e.g. "you can only add your own uid to memberIds", "you
// can only write a challenge where you're fromUid or toUid") which is harder
// to get right in rules syntax, and this repo has no Firebase emulator or
// staging project to test against before it goes live. A wrong rule here
// fails silently and can lock real users out of features that work today —
// worse than the current over-permissiveness. Draft below for review before
// deploying (test in the Firebase emulator first):
