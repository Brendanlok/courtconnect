rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read anyone's profile (needed for username lookup, club
    // member resolution, chat headers, etc.) but only write their own.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      // Per-user subcollections — always written by their own owner (uid),
      // never by anyone else. Every function in firestoreService.ts that
      // touches these already only ever writes to auth.currentUser's own uid.
      match /matches/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
      match /plannedMatches/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
      match /tournamentRegs/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
      match /conversations/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
      match /friends/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // The one subcollection someone ELSE writes into — fromUid (the
      // endorser) writes their own doc under the target's uid.
      match /endorsements/{fromUid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == fromUid;
      }
    }

    // Shared, multi-party collections — kept permissive for any authenticated
    // user. NOTE: these are explicitly listed (not a catch-all wildcard) so
    // that tightening `users/**` above actually takes effect — Firestore
    // rules are OR'd across every matching `match` block, so a leftover
    // `match /{collection}/{document=**}` here would silently re-grant
    // access to the subcollections just locked down above. See the bottom of
    // this file for why a fuller per-field tightening of these four isn't
    // applied yet.
    match /liveMatches/{document=**}   { allow read, write: if request.auth != null; }
    match /challenges/{document=**}    { allow read, write: if request.auth != null; }
    match /conversations/{document=**} { allow read, write: if request.auth != null; }
    match /clubs/{document=**}         { allow read, write: if request.auth != null; }
  }
}

// ── Not yet applied: proposed tighter rules for the 4 shared collections
// above. These need real per-field write validation (e.g. "you can only add
// your own uid to memberIds", "you can only write a challenge where you're
// fromUid or toUid") which is harder to get right in rules syntax, and this
// repo has no Firebase emulator or staging project to test against before it
// goes live. A wrong rule here fails silently and can lock real users out of
// features that work today — worse than the current over-permissiveness.
// Draft below for review before deploying (test in the Firebase emulator
// first: `firebase emulators:start`):
//
