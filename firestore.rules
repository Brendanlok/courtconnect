//   allow read: if request.auth != null;
//   allow create: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
//   allow update: if request.auth != null &&
//     (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
// }
// match /conversations/{chatId} {
//   allow read: if request.auth != null;
//   allow write: if request.auth != null && request.auth.uid in request.resource.data.participantUids;
// }
// match /clubs/{id} {
//   allow read: if request.auth != null;
//   allow create: if request.auth != null && request.resource.data.adminId == request.auth.uid;
//   // Update rule intentionally omitted — needs a real "only your own uid was
//   // added/removed from memberIds/pendingIds, OR you're already adminId/in
//   // moderatorIds" check, which needs emulator testing to get right without
//   // breaking joinClub/leaveClub/acceptClubMember/etc. for real users.
// }
//
// This repo also has no firebase.json / .firebaserc — editing this file does
// NOT auto-deploy it. It must be manually pasted into the Firebase Console
// (Firestore → Rules) or pushed with `firebase deploy --only firestore:rules`
// after `firebase init` is set up, for either the applied or draft rules
// above to actually take effect.
