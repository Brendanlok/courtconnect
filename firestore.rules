// Tested against the local Firestore emulator — see tests/firestore-rules.test.mjs
// (`npm run test:rules`, 22/22 checks passing). NOT auto-deployed: .firebaserc
// points at the fake "demo-courtconnect" project used only for emulator
// testing, deliberately, so a stray `firebase deploy` can't accidentally push
// to a real project. To actually publish these rules, either paste this file
// into the Firebase Console (Firestore → Rules) for the real project, or run
// `firebase deploy --only firestore:rules --project <your-real-project-id>`.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdminOrMod(club) {
      return club.data.adminId == request.auth.uid
        || (('moderatorIds' in club.data) && request.auth.uid in club.data.moderatorIds);
    }

    // "The only change to this array is my own uid being added or removed" —
    // matches exactly what arrayUnion(uid)/arrayRemove(uid) produce client-side.
    function selfOnlyChange(before, after) {
      return after == before
        || after == before.concat([request.auth.uid])
        || after == before.removeAll([request.auth.uid]);
    }

    // Users can read anyone's profile (needed for username lookup, club
    // member resolution, chat headers, etc.) but only write their own.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      // Per-user subcollections — always written by their own owner (uid),
      // never by anyone else. Every function in firestoreService.ts that
      // touches these already only ever writes to auth.currentUser's own uid.
      match /matches/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
      match /plannedMatches/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
      match /tournamentRegs/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
      match /conversations/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
      match /friends/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // The one subcollection someone ELSE writes into — fromUid (the
      // endorser) writes their own doc under the target's uid.
      match /endorsements/{fromUid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == fromUid;
      }
    }

    match /liveMatches/{document=**} {
      allow read, write: if request.auth != null;
    }

    // A challenge can only be created by the person it's from, and only
    // updated (accept/decline/cancel) by whichever party it's between.
    match /challenges/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
      allow update: if request.auth != null &&
        (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow delete: if false;
    }

    // A real cross-account match report. Only the reporter can create it (and
    // must list themselves as reporterUid and a participant); either
    // participant can update it afterward (confirm/dispute/withdraw/mark
    // their own MMR applied) — same broad-update-between-the-two-parties
    // shape as challenges, not split into per-field rules.
    match /matches/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.reporterUid == request.auth.uid
        && request.auth.uid in request.resource.data.participantUids;
      allow update: if request.auth != null && request.auth.uid in resource.data.participantUids;
      allow delete: if false;
    }

    // A conversation can only be written by one of its two participants.
    match /conversations/{chatId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid in request.resource.data.participantUids;
      allow delete: if false;
    }

    match /clubs/{clubId} {
      allow read: if request.auth != null;

      // Whoever creates a club must list themselves as its sole admin/member.
      allow create: if request.auth != null
        && request.resource.data.adminId == request.auth.uid
        && request.resource.data.memberIds == [request.auth.uid];

      // Either you're already trusted to manage this club (admin/mod — can
      // change anything: settings, moderators, accept/decline members), or
      // this is a self-service join/leave/request/cancel that only touches
      // your own uid in memberIds/pendingIds and nothing else.
      allow update: if request.auth != null && (
        isAdminOrMod(resource) ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'pendingIds']) &&
          selfOnlyChange(resource.data.memberIds, request.resource.data.memberIds) &&
          selfOnlyChange(resource.data.pendingIds, request.resource.data.pendingIds)
        ) ||
        (
          // One-time legacy-chat migration cleanup (migrateLegacyClubMessages):
          // any member can clear the old embedded clubMessages field — never
          // re-populate or rewrite it — once its contents are copied into the
          // messages subcollection.
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clubMessages']) &&
          !('clubMessages' in request.resource.data) &&
          request.auth.uid in resource.data.memberIds
        )
      );

      allow delete: if request.auth != null && resource.data.adminId == request.auth.uid;

      // Chat is create-only (no edit/delete once sent), members-only to
      // write OR read. Deliberately doesn't also require
      // senderId == request.auth.uid: the one-time legacy-message migration
      // (see migrateLegacyClubMessages) writes messages authored by OTHER
      // past members under whichever member's session first opens the chat
      // — there's no admin/Cloud Functions backend to run it as a trusted
      // system write instead. Residual tradeoff: a member can technically
      // attribute a message to a fellow member's name, not just their own —
      // acceptable for a club chat, not for anything security-sensitive.
      match /messages/{msgId} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/clubs/$(clubId)).data.memberIds;
        allow create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/clubs/$(clubId)).data.memberIds;
        allow update, delete: if false;
      }
    }
  }
}
