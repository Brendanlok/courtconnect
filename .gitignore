# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# telegram bot downloaded screenshots
/telegram-bot/screenshots/

# telegram bot token + chat IDs — a live credential, was committed in plaintext
# (see git history); untracked from here on, see config.example.json for the shape
/telegram-bot/config.json

# locally-installed Claude skills (not part of the app)
/.agents/

# Firebase emulator (used for testing firestore.rules — see `npm run test:rules`)
firestore-debug.log
firebase-debug.log
ui-debug.log
.firebase/
